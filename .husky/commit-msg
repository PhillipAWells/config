#!/bin/sh
# Husky commit-msg hook
# 1. Enforces Conventional Commits format
# 2. Rejects Co-Authored-By lines

COMMIT_MSG_FILE="$1"

# Extract the subject line: first non-empty, non-comment line
SUBJECT=$(grep -v '^#' "$COMMIT_MSG_FILE" | grep -v '^[[:space:]]*$' | head -1)

# Exempt merge commits, revert commits, and bare version strings (e.g. 3.0.0 release merges)
case "$SUBJECT" in
  Merge\ *|Revert\ *|[0-9]*.[0-9]*.[0-9]*)
    ;;
  *)
    # Validate Conventional Commits format:
    # <type>(<optional scope>): <subject>
    # Allowed types: feat, fix, chore, docs, test, refactor, build, ci
    if ! echo "$SUBJECT" | grep -Eq '^(feat|fix|chore|docs|test|refactor|build|ci)(\([^)]+\))?: .+'; then
      cat >&2 <<'EOF'

Commit rejected: subject line does not follow Conventional Commits format.

Expected format:
  <type>(<optional scope>): <subject>

Allowed types:
  feat, fix, chore, docs, test, refactor, build, ci

Examples:
  feat(config): add support for nested schema validation
  fix(config-provider-env): handle missing dotenv file gracefully
  chore: update vitest to 4.1.0

Please reword your commit message and try again.

EOF
      exit 1
    fi
    ;;
esac

# Reject Co-Authored-By lines (project policy: single-author commits only)
if grep -q "Co-Authored-By" "$COMMIT_MSG_FILE"; then
  cat >&2 <<'EOF'

Commit rejected: Co-Authored-By line found

This project does not use co-authored commits. Each commit must be authored
by a single person or system. See .claude/settings.json for policy configuration.

Please remove the 'Co-Authored-By' line(s) and try again.

EOF
  exit 1
fi

exit 0
